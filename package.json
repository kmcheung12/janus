    "@vitest/coverage-v8": "^4.1.5",
    "@wxt-dev/module-svelte": "^2.0.4",
    "jsdom": "^29.1.1",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wxt": "^0.20.26"
  }
}
